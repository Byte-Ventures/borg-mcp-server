{
  "name": "borgmcp-server",
  "version": "0.1.11",
  "private": false,
  "description": "Self-hosted Borg coordination server",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byte-Ventures/borg-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/Byte-Ventures/borg-mcp-server/issues"
  },
  "homepage": "https://github.com/Byte-Ventures/borg-mcp-server#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "bin": {
    "borg-mcp-server": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "NOTICE",
    "README.md",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md",
    "npm-shrinkwrap.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run build && npm run typecheck && npm test",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:artifact": "node scripts/verify-packed-artifact.mjs"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "borgmcp-shared": "0.4.3",
    "selfsigned": "5.5.0"
  }
}
